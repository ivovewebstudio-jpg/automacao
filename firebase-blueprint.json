{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information for I9webstudio platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the user account was last updated." }
      },
      "required": ["uid", "email", "role", "createdAt", "updatedAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A potential customer captured through chat automation or contact forms.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "source": { "type": "string", "description": "Source of the lead (Instagram, WhatsApp, Web, etc.)" },
        "status": { "type": "string", "enum": ["new", "contacted", "converted", "lost"] },
        "ownerId": { "type": "string", "description": "The UID of the user who owns this lead." },
        "createdAt": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "email", "ownerId", "status", "createdAt"]
    },
    "Automation": {
      "title": "Automation",
      "description": "A workflow/flow configuration for chat automation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "platform": { "type": "string", "enum": ["instagram", "whatsapp", "messenger"] },
        "ownerId": { "type": "string" },
        "config": { "type": "object", "description": "The JSON configuration of the flow." },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "platform", "ownerId", "isActive", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profile and access levels."
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Stores captured leads."
    },
    "/automations/{automationId}": {
      "schema": "Automation",
      "description": "Stores automation flow definitions."
    }
  }
}
