rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // 1. PRIMITIVES & HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    
    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Admin check: Bootstrap with user email
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "ivovewebstudio@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // -------------------------------------------------------------------------
    // 2. VALIDATION BLUEPRINTS
    // -------------------------------------------------------------------------

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 255 &&
             data.role in ['user', 'admin'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidLead(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.matches('^.+@.+$') &&
             data.ownerId == request.auth.uid &&
             data.status in ['new', 'contacted', 'converted', 'lost'] &&
             data.createdAt == request.time &&
             (data.get('tags', []).size() <= 10);
    }

    function isValidAutomation(data) {
      return data.title is string && data.title.size() <= 100 &&
             data.platform in ['instagram', 'whatsapp', 'messenger'] &&
             data.ownerId == request.auth.uid &&
             data.isActive is bool &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // -------------------------------------------------------------------------
    // 3. COLLECTIONS
    // -------------------------------------------------------------------------

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // USERS
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isEmailVerified() && 
                      isValidId(userId) && userId == request.auth.uid &&
                      isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isOwner(userId) && 
                      incoming().role == existing().role && // Can't elevate self
                      incoming().uid == existing().uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']) &&
                      incoming().updatedAt == request.time;
    }

    // LEADS
    match /leads/{leadId} {
      allow get: if isOwner(existing().ownerId) || isAdmin();
      allow list: if isOwner(request.query.limit > 0 && incoming().ownerId == request.auth.uid) || isAdmin(); 
      // Rule 8: Secure list queries
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      
      allow create: if isSignedIn() && isEmailVerified() && 
                      isValidId(leadId) &&
                      isValidLead(incoming());
                      
      allow update: if isOwner(existing().ownerId) &&
                      incoming().ownerId == existing().ownerId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasAny(['status', 'tags', 'name', 'email']) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'tags', 'name', 'email', 'updatedAt']) &&
                      (incoming().status != existing().status ? incoming().status in ['contacted', 'converted', 'lost'] : true);
    }

    // AUTOMATIONS
    match /automations/{automationId} {
      allow read: if isOwner(resource.data.ownerId) || isAdmin();
      allow create: if isSignedIn() && isEmailVerified() && 
                      isValidId(automationId) &&
                      isValidAutomation(incoming());
      allow update: if isOwner(existing().ownerId) &&
                      incoming().ownerId == existing().ownerId &&
                      incoming().diff(existing()).affectedKeys().hasAny(['title', 'config', 'isActive', 'updatedAt']) &&
                      incoming().updatedAt == request.time;
      allow delete: if isOwner(existing().ownerId);
    }

    // ADMINS (Trusted source for roles)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
